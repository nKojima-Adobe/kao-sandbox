{
  "definitions": [
    {
      "title": "ボタン - {BLOCK_FUNC}",
      "id": "{BLOCK_NAME}",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "ボタン - {BLOCK_FUNC}",
              "filter": "{BLOCK_NAME}",
              "model": "{BLOCK_NAME}"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "{BLOCK_NAME}",
      "fields": [
        {
          "component": "aem-content",
          "name": "link",
          "label": "リンク - Link",
          "valueType": "string",
          "valueFormat": "regexp",
          "validation": {
            "regExp": "^(https?://[^\\s/$.?#].[^\\s]*|/[^\\s]*|#[^\\s]*|mailto:[^\\s@]+@[^\\s@]+\\.[^\\s@]+|tel:[+]?[0-9\\s\\-\\(\\)]+)$",
            "customErrorMsg": "提供された場合の有効なURL形式 - Please enter a valid URL (https://example.com)"
          }
        },
        {
          "component": "text",
          "name": "linkText",
          "label": "テキスト - Text",
          "valueType": "string",
          "default": "Button",
          "required": true,
          "validation": {
            "minLength": 1,
            "customErrorMsg": "ボタンテキストを 1 文字以上で入力してください - Please enter the button text with at least 1 character"
          }
        },
        {
          "component": "text",
          "name": "linkTitle",
          "label": "タイトル - Title",
          "valueType": "string",
          "default": "Button",
          "validation": {
            "minLength": 1,
            "errorMessage": "タイトルを 1 文字以上で入力してください - Please enter the title with at least 1 character"
          }
        },
        {
          "component": "select",
          "name": "classes",
          "label": "ボタンタイプ - Button Type",
          "value": "",
          "valueType": "string",
          "options": [
            {
              "name": "塗りつぶし - Filled",
              "value": ""
            },
            {
              "name": "アウトライン - Outlined",
              "value": "button-outlined"
            },
            {
              "name": "テキスト - Text",
              "value": "button-text"
            },
            {
              "name": "アンカー - Anchor",
              "value": "button-anchor"
            },
            {
              "name": "ナビゲーション - Nav",
              "value": "button-nav"
            }
          ],
          "default": ""
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "{BLOCK_NAME}",
      "components": []
    }
  ]
}
