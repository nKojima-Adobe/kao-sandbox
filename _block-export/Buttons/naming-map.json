{
  "blockType": "single",
  "originalNames": {
    "blockName": "buttons",
    "classPrefix": "buttons",
    "functionPrefix": "Buttons",
    "variablePrefix": "buttons",
    "constantPrefix": "BUTTONS"
  },
  "placeholders": {
    "{BLOCK_NAME}": "kebab-case (file names, folder names, JSON IDs, block wrapper class)",
    "{BLOCK_CLASS}": "CSS block wrapper class (kebab-case, same as {BLOCK_NAME})",
    "{BLOCK_FUNC}": "PascalCase (display names, titles)",
    "{BLOCK_VAR}": "camelCase (same as block name since no hyphens)",
    "{BLOCK_UPPER}": "SCREAMING_SNAKE (not used in this block)"
  },
  "designSystemNote": {
    "_important": "This block defines the GLOBAL '.button' class (singular) used across the entire EDS project. The '.button' class and its variants (.button-outlined, .button-text, .button-anchor, .button-nav, .button-caption) are NOT replaced with placeholders because they are design system tokens referenced by many other blocks. Only the block wrapper class '.buttons' (plural) is replaced.",
    "blockWrapperClass": ".buttons → .{BLOCK_CLASS}",
    "globalButtonClass": ".button (PRESERVED — design system token)",
    "globalVariantClasses": [
      ".button-outlined (PRESERVED)",
      ".button-text (PRESERVED)",
      ".button-anchor (PRESERVED)",
      ".button-nav (PRESERVED)",
      ".button-caption (PRESERVED)"
    ]
  },
  "files": [
    "{BLOCK_NAME}.js",
    "{BLOCK_NAME}.css",
    "{BLOCK_NAME}.stories.js",
    "_{BLOCK_NAME}.json"
  ],
  "cssClasses": {
    "blockLevel": [".{BLOCK_CLASS}"],
    "designSystem_preserved": [
      ".button",
      ".button-outlined",
      ".button-text",
      ".button-anchor",
      ".button-nav",
      ".button-caption",
      "a.button",
      "a.button-outlined",
      "a.button-text",
      "a.button-anchor",
      "a.button-nav"
    ]
  },
  "jsFunctions": [
    "decorate (default export)",
    "createButton (internal)",
    "isValidUrl (internal)"
  ],
  "externalDependencies": [
    {
      "name": "normalizeAltText",
      "source": "../../utils/generic-utils.js",
      "required": true,
      "purpose": "Strips icon tokens and artifacts from title attribute text"
    }
  ],
  "replacements": [
    {"type": "filename", "original": "buttons.js", "placeholder": "{BLOCK_NAME}.js"},
    {"type": "filename", "original": "buttons.css", "placeholder": "{BLOCK_NAME}.css"},
    {"type": "filename", "original": "buttons.stories.js", "placeholder": "{BLOCK_NAME}.stories.js"},
    {"type": "filename", "original": "_buttons.json", "placeholder": "_{BLOCK_NAME}.json"},
    {"type": "json-id", "original": "\"buttons\"", "placeholder": "\"{BLOCK_NAME}\""},
    {"type": "json-title", "original": "Buttons", "placeholder": "{BLOCK_FUNC}", "context": "In display titles only"},
    {"type": "stories-title", "original": "title: 'Blocks/Buttons'", "placeholder": "title: 'Blocks/{BLOCK_FUNC}'"},
    {"type": "stories-class", "original": "wrapper.className = 'buttons'", "placeholder": "wrapper.className = '{BLOCK_NAME}'"},
    {"type": "js-comment", "original": "Button Block", "placeholder": "{BLOCK_FUNC} Block", "context": "Comment header"},
    {"type": "stories-import", "original": "./buttons.css", "placeholder": "./{BLOCK_NAME}.css"},
    {"type": "preserved", "original": ".button", "note": "NOT replaced — global design system class"},
    {"type": "preserved", "original": ".button-outlined", "note": "NOT replaced — design system variant"},
    {"type": "preserved", "original": ".button-text", "note": "NOT replaced — design system variant"},
    {"type": "preserved", "original": ".button-anchor", "note": "NOT replaced — design system variant"},
    {"type": "preserved", "original": ".button-nav", "note": "NOT replaced — design system variant"},
    {"type": "preserved", "original": ".button-caption", "note": "NOT replaced — design system sub-element"}
  ]
