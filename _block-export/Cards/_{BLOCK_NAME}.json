{
  "definitions": [
    {
      "title": "カード - {BLOCK_FUNC}",
      "id": "{BLOCK_NAME}",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "カード - {BLOCK_FUNC}",
