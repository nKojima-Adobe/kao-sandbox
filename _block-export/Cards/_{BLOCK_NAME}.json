        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "カード - {BLOCK_CHILD_FUNC}",
              "model": "{BLOCK_CHILD}"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "{BLOCK_NAME}",
      "fields": [
        {
          "component": "text",
          "name": "ctaText",
          "label": "CTAボタンテキスト - CTA Button Text",
          "valueType": "string"
        },
        {
          "component": "aem-content",
          "name": "ctaLink",
          "label": "CTAボタンリンク - CTA Button Link",
          "valueType": "string",
          "valueFormat": "regexp",
          "validation": {
            "regExp": "^(https?://[^\\s/$.?#].[^\\s]*|/[^\\s]*|#[^\\s]*|mailto:[^\\s@]+@[^\\s@]+\\.[^\\s@]+|tel:[+]?[0-9\\s\\-\\(\\)]+)$",
            "customErrorMsg": "有効なURL形式を入力してください - Please enter a valid URL format"
          }
        },
        {
          "component": "select",
          "name": "layoutVariant",
          "value": "grid",
          "label": "レイアウトバリエーション - Layout Variant",
          "valueType": "string",
          "options": [
            {
              "name": "グリッドレイアウト - Grid Layout",
              "value": "grid"
            },
            {
              "name": "カルーセルレイアウト - Carousel Layout",
              "value": "carousel"
            }
          ],
          "default": "grid"
        }
      ]
    },
    {
      "id": "{BLOCK_CHILD}",
      "fields": [
        {
          "component": "select",
          "name": "cardType",
          "value": "topic",
          "label": "カードタイプ - {BLOCK_CHILD_FUNC} Type",
          "valueType": "string",
          "options": [
            {
              "name": "トピックカード（リンク） - Topic {BLOCK_CHILD_FUNC} (Links)",
              "value": "topic"
            },
            {
              "name": "投稿カード（記事コンテンツ） - Post {BLOCK_CHILD_FUNC} (Article Content)",
              "value": "post"
            }
          ],
          "default": "topic"
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "image",
          "label": "画像 - Image",
          "multi": false,
          "condition": {
            "===": [{ "var": "cardType" }, "topic"]
          }
        },
        {
          "component": "text",
          "name": "imageAlt",
          "label": "画像代替テキスト - Image Alt Text",
          "valueType": "string",
          "required": true,
          "condition": {
            "and": [
              { "var": "image" },
              { "===": [{ "var": "cardType" }, "topic"] }
            ]
          },
          "validation": {
            "messages": {
              "required": "画像には代替テキストが必要です - Alt text is required for images"
            },
            "customErrorMsg": "画像には代替テキストが必要です - Alt text is required for images"
          }
        },
        {
          "component": "aem-content",
          "name": "imageLink",
          "label": "画像リンク - Image Link",
          "valueType": "string",
          "valueFormat": "regexp",
          "condition": {
            "and": [
              { "var": "image" },
              { "===": [{ "var": "cardType" }, "topic"] }
            ]
          },
          "validation": {
            "regExp": "^(https?://[^\\s/$.?#].[^\\s]*|/[^\\s]*|#[^\\s]*|mailto:[^\\s@]+@[^\\s@]+\\.[^\\s@]+|tel:[+]?[0-9\\s\\-\\(\\)]+)$",
            "customErrorMsg": "有効なURL形式を入力してください - Please enter a valid URL format"
