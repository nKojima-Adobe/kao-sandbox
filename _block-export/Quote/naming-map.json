{
  "blockType": "single",
  "originalNames": {
    "blockName": "quote",
    "classPrefix": "quote",
    "functionPrefix": "Quote",
    "variablePrefix": "quote",
    "constantPrefix": "QUOTE"
  },
  "placeholders": {
    "{BLOCK_NAME}": "quote (kebab-case — block name, file names, CSS class prefix, JSON IDs)",
    "{BLOCK_CLASS}": "quote (same as BLOCK_NAME)",
    "{BLOCK_FUNC}": "Quote (PascalCase — display titles, Storybook)",
    "{BLOCK_VAR}": "quote (camelCase — same as BLOCK_NAME for single-word)"
  },
  "files": {
    "extracted": [
      "{BLOCK_NAME}.js",
      "{BLOCK_NAME}.css",
      "{BLOCK_NAME}.stories.js",
      "_{BLOCK_NAME}.json"
    ],
    "documentation": [
      "naming-map.json",
      "model-snippet.json",
      "global-typography-snippet.css",
      "extraction-information.md",
      "description.md",
      "summary.md",
      "README.md",
      "implementation.md"
    ]
  },
  "replacements": [
    {"type": "file-name", "original": "quote.js", "placeholder": "{BLOCK_NAME}.js"},
    {"type": "file-name", "original": "quote.css", "placeholder": "{BLOCK_NAME}.css"},
    {"type": "file-name", "original": "quote.stories.js", "placeholder": "{BLOCK_NAME}.stories.js"},
    {"type": "file-name", "original": "_quote.json", "placeholder": "_{BLOCK_NAME}.json"},
    {"type": "import-path", "original": "'./quote.js'", "placeholder": "'./{BLOCK_NAME}.js'"},
    {"type": "import-path", "original": "'./quote.css'", "placeholder": "'./{BLOCK_NAME}.css'"},
    {"type": "css-class", "original": ".quote", "placeholder": ".{BLOCK_NAME}", "context": "block wrapper and all sub-element prefixes"},
    {"type": "json-id", "original": "\"quote\"", "placeholder": "\"{BLOCK_NAME}\"", "context": "definition/model/filter IDs"},
    {"type": "title", "original": "Quote", "placeholder": "{BLOCK_FUNC}", "context": "PascalCase in titles and Storybook"}
  ]
}
